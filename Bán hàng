#include <Servo.h>
#include <SoftwareSerial.h> 

// 4 Servo nhả hàng D1, D2, D3, D4
const int PIN_SERVO_MON[4] = {D1, D2, D3, D4}; 
// Servo mở cửa tủ D5
const int PIN_SERVO_CUA = D5;

SoftwareSerial ngheESP1(13, -1); 

Servo servoMon[4];
Servo servoCua;

// biến nhớ xem cửa đang đóng hay mở
bool cuaDangMo = false; 

void setup() {
  ngheESP1.begin(9600);

  for (int i = 0; i < 4; i++) {
    servoMon[i].attach(PIN_SERVO_MON[i]);
    servoMon[i].write(90);
  }
  
  servoCua.attach(PIN_SERVO_CUA);
  servoCua.write(0);
}

void loop() {
  if (ngheESP1.available() > 0) {
    String duLieu = ngheESP1.readStringUntil('\n'); 
    duLieu.trim(); 

    // --- 1. XỬ LÝ LỆNH NHẢ HÀNG ---
    if (duLieu.startsWith("NHA_HANG:")) {
      int idMon = duLieu.substring(9).toInt();
      
      if (idMon >= 0 && idMon < 4) {
        servoMon[idMon].write(0);  // Rớt lon
        delay(500); 
        servoMon[idMon].write(90);
      }
    }
    
    // --- 2. XỬ LÝ LỆNH ĐÓNG/MỞ CỬA CHO NHÂN VIÊN ---
    else if (duLieu == "MO_CUA") {
      // Logic Bật/Tắt (Toggle)
      if (cuaDangMo == false) {
        // Cửa đang đóng -> Quẹt thẻ thì MỞ RA
        servoCua.write(90); 
        cuaDangMo = true;
      } 
      else {
        // Cửa đang mở -> Quẹt thẻ thì ĐÓNG LẠI
        servoCua.write(0);  
        cuaDangMo = false; // Nhớ là cửa đã đóng
      }
    }
  }
}
